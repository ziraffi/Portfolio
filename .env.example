# Cloudflare Turnstile Keys
# Get these from: https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Google OAuth Keys (Client-side)
# Get these from: https://console.cloud.google.com/apis/credentials
# For local development, add:
# - Authorized JavaScript origins: http://localhost:3000
# - Authorized redirect URIs: http://localhost:3000
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# EmailJS Configuration (Phase 5)
# Get these from https://dashboard.emailjs.com/
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id (Admin Notification)
VITE_EMAILJS_AUTOREPLY_TEMPLATE_ID=your_id_here (Client Auto-Reply)
VITE_EMAILJS_PUBLIC_KEY=your_public_key
